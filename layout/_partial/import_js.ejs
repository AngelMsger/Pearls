<!-- Import prettify js  -->
<% if (theme.prettify.enable){ %>
    <% if ( (is_post()) ) { %>
        <% if(theme.vendors.prettify) { %>
            <script src="<%= theme.vendors.prettify %>" defer></script>
        <% } else { %>
            <script src="<%= url_for('js/prettify.min.js') %>" defer></script>
        <% } %>
    <% } %>
<% } %>
<% if (theme.hanabi.enable) { %>
    <script src="<%= url_for('js/hanabi-browser-bundle.js') %>" defer></script>
<% } %>

<script>
    window.materialThemeEnhancers = window.materialThemeEnhancers || {};
    window.materialThemeEnhancers.prettify = <%= theme.prettify.enable && is_post() ? 'true' : 'false' %>;
    window.materialThemeEnhancers.hanabi = <%= theme.hanabi.enable ? 'true' : 'false' %>;
    window.materialThemeEnhancers.hanabiLineNumber = <%= theme.hanabi.line_number ? 'true' : 'false' %>;
    window.materialThemeEnhancers.hanabiIncludeDefaultColors = <%= theme.hanabi.includeDefaultColors ? 'true' : 'false' %>;
    window.materialThemeEnhancers.hanabiColors = <%- JSON.stringify(theme.hanabi.customColors || null) %>;
</script>

<!-- MathJax Load-->
<% if (page.mathjax) { %>
    <%- partial('_widget/mathjax') %>
<% } %>

<!-- Bing Background -->
<% if(theme.background.bing.enable) { %>
<% } %>

<!-- Custom Footer -->

<% if (site.data.footer) { %>
    <% for (var i in site.data.footer) { %>
        <%- site.data.footer[i] %>
    <% } %>
<% } %>

<script src="<%= url_for('js/progressive.js') %>" defer></script>
