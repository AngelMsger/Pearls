<!-- Paradox Post Header -->
<% if(!page.thumbnail) { %>
    <% if(!theme.thumbnail.purecolor) {%>
        <!-- Random Thumbnail -->
        <% var headerRandomThumbnail = Math.floor(Math.random() * theme.thumbnail.random_amount) + 1; %>
        <div class="post_thumbnail-random progressive-media progressive-bg is-loading mdl-card__media mdl-color-text--grey-50" data-progressive-bg="post-header" style="--progressive-bg:url('<%= url_for(theme.img.random_thumbnail) %><%= headerRandomThumbnail %>.png')">
    <% } else { %>
        <!-- Pure Thumbnail -->
        <div class="post_thumbnail-pure mdl-card__media mdl-color-text--grey-50" style="background-color:<%= theme.thumbnail.purecolor %> !important">
    <% } %>
<% }else{ %>
    <!-- Custom Thumbnail -->
    <div class="post_thumbnail-custom progressive-media progressive-bg is-loading mdl-card__media mdl-color-text--grey-50" data-progressive-bg="post-header" style="--progressive-bg:url('<%- page.thumbnail %>')">
<% } %>
        <p class="article-headline-p">
            <%- page.title %>
        </p>
    </div>
