<% if(theme.vendors.nprogress) { %>
    <%- jsLsload({path:(theme.vendors.nprogress),key:'np_js'}) %>
<% } else if(theme.vendors.materialcdn) { %>
    <%- jsLsload({path:(theme.vendors.materialcdn + '/js/nprogress.js'),key:'np_js'}) %>
<% } else { %>
    <%- jsLsload({path:('js/nprogress.js'),key:'np_js'}) %>
<% } %>

<script type="text/ls-javascript" id="NProgress-script">
    (function() {
        function revealFadeElements() {
            var elements = document.querySelectorAll('.fade.out');
            Array.prototype.forEach.call(elements, function(element) {
                element.classList.remove('out');
            });
        }

        function applyNProgressStyles() {
            var bar = document.querySelector('#nprogress .bar');
            var peg = document.querySelector('#nprogress .peg');
            var spinner = document.querySelector('#nprogress .spinner-icon');

            if (bar) {
                bar.style.background = '<%= theme.uiux.nprogress_color %>';
            }

            if (peg) {
                peg.style.boxShadow = '0 0 10px <%= theme.uiux.nprogress_color %>, 0 0 15px <%= theme.uiux.nprogress_color %>';
            }

            if (spinner) {
                spinner.style.borderTopColor = '<%= theme.uiux.nprogress_color %>';
                spinner.style.borderLeftColor = '<%= theme.uiux.nprogress_color %>';
            }
        }

        if (window.NProgress) {
            NProgress.configure({
                showSpinner: true
            });
            NProgress.start();
            applyNProgressStyles();
        }

        setTimeout(function() {
            if (window.NProgress) {
                NProgress.done();
            }

            revealFadeElements();
        }, <%= theme.uiux.nprogress_buffer %>);
    })();
</script>
